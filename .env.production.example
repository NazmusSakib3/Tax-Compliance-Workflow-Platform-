# Copy to a secret-managed production environment file or deployment platform.
# Never commit real values.

PUBLIC_APP_ORIGIN=https://tax-compliance.example.com
PUBLIC_HTTP_PORT=80
NG_APP_API_BASE_URL=/api

POSTGRES_DB=taxcompliance
POSTGRES_USER=taxcompliance_app
POSTGRES_PASSWORD=replace-with-strong-database-password

REDIS_PASSWORD=replace-with-strong-redis-password

RABBITMQ_DEFAULT_USER=taxcompliance_notifications
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbitmq-password

Jwt__SigningKey=replace-with-at-least-32-random-characters
Seed__AdminEmail=admin@example.com
Seed__AdminPassword=replace-with-temporary-strong-admin-password
Notifications__DefaultRecipientEmail=compliance-ops@example.com

Email__FromAddress=no-reply@example.com
Email__FromName=Tax Compliance Workflow Platform
Email__SmtpHost=smtp.example.com
Email__SmtpPort=587
Email__EnableSsl=true
Email__Username=smtp-user
Email__Password=replace-with-smtp-password

PasswordReset__ClientResetUrl=https://tax-compliance.example.com/reset-password

# Optional: OTLP collector endpoint for distributed tracing (leave empty to disable export)
OTEL_EXPORTER_OTLP_ENDPOINT=
