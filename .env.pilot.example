# Local pilot/staging environment. Copy to .env.pilot and adjust before deploy.
# Never commit .env.pilot — it contains generated secrets.

PUBLIC_APP_ORIGIN=http://localhost:8088
PUBLIC_HTTP_PORT=8088
NG_APP_API_BASE_URL=/api

POSTGRES_DB=taxcompliance
POSTGRES_USER=taxcompliance_app
POSTGRES_PASSWORD=replace-with-strong-database-password

REDIS_PASSWORD=replace-with-strong-redis-password

RABBITMQ_DEFAULT_USER=taxcompliance_notifications
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbitmq-password

Jwt__SigningKey=replace-with-at-least-32-random-characters
Seed__AdminEmail=admin@pilot.local
Seed__AdminPassword=replace-with-temporary-strong-admin-password
Notifications__DefaultRecipientEmail=admin@pilot.local

Email__FromAddress=no-reply@pilot.local
Email__FromName=Tax Compliance Pilot
Email__SmtpHost=mailhog
Email__SmtpPort=1025
Email__EnableSsl=false
Email__Username=pilot
Email__Password=pilot

PasswordReset__ClientResetUrl=http://localhost:8088/reset-password

MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Written by scripts/pilot-release.ps1 after admin password rotation:
# PILOT_ADMIN_ROTATED_PASSWORD=
