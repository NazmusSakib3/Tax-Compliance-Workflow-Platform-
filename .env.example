# Copy to .env for local development. Use .env.production.example as the
# checklist for production deployments.

POSTGRES_DB=taxcompliance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-only

# Local development defaults. Replace these in shared environments.
Jwt__SigningKey=change-me-to-a-local-development-secret-32-chars-min
Seed__AdminEmail=admin@taxplatform.local
Seed__AdminPassword=change-me-local-only
Notifications__DefaultRecipientEmail=admin@taxplatform.local

# Connection strings (optional overrides)
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=taxcompliance;Username=postgres;Password=change-me-local-only
# ConnectionStrings__Redis=localhost:6379
