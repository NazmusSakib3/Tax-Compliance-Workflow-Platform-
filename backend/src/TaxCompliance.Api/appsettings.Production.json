{
  "ApplicationName": "Tax Compliance Workflow Platform",
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "TaxCompliance.Api",
    "Audience": "TaxCompliance.AngularSpa",
    "SigningKey": "",
    "ExpirationMinutes": 60
  },
  "Security": {
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutMinutes": 15
    },
    "LoginRateLimit": {
      "PermitLimit": 20,
      "WindowMinutes": 1
    }
  },
  "PasswordReset": {
    "ClientResetUrl": ""
  },
  "Email": {
    "Provider": "Smtp",
    "FromAddress": "",
    "FromName": "Tax Compliance Workflow Platform",
    "SmtpHost": "",
    "SmtpPort": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": ""
  },
  "Seed": {
    "AdminEmail": "",
    "AdminPassword": "",
    "AdminDisplayName": "Platform Administrator"
  },
  "OccurrenceGeneration": {
    "MonthsAheadToGenerate": 12
  },
  "FileStorage": {
    "RootPath": "storage/uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".csv", ".png", ".jpg", ".jpeg", ".txt" ]
  },
  "RabbitMq": {
    "HostName": "",
    "QueueName": "taxcompliance.notifications"
  },
  "Notifications": {
    "DueSoonDays": 7,
    "ScanIntervalMinutes": 30,
    "DefaultRecipientEmail": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "DataProtection": {
    "KeysPath": "/app/data-protection-keys"
  },
  "SecurityHeaders": {
    "EnableHsts": true
  },
  "OpenTelemetry": {
    "ServiceName": "TaxCompliance.Api",
    "OtlpEndpoint": ""
  },
  "AllowedHosts": "*"
}
