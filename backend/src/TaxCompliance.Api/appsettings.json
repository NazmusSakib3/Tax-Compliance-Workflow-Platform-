{
  "ApplicationName": "Tax Compliance Workflow Platform",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=taxcompliance;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "TaxCompliance.Api",
    "Audience": "TaxCompliance.AngularSpa",
    "SigningKey": "ChangeThisDevelopmentKeyToALongerSecret12345",
    "ExpirationMinutes": 60
  },
  "Security": {
    "Lockout": {
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutMinutes": 15
    },
    "LoginRateLimit": {
      "PermitLimit": 60,
      "WindowMinutes": 1
    }
  },
  "PasswordReset": {
    "ClientResetUrl": "http://localhost:4200/reset-password"
  },
  "Email": {
    "Provider": "Development",
    "FromAddress": "no-reply@taxplatform.local",
    "FromName": "Tax Compliance Workflow Platform",
    "SmtpHost": "",
    "SmtpPort": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": ""
  },
  "Seed": {
    "AdminEmail": "admin@taxplatform.local",
    "AdminPassword": "Admin123!",
    "AdminDisplayName": "Platform Administrator"
  },
  "OccurrenceGeneration": {
    "MonthsAheadToGenerate": 12
  },
  "FileStorage": {
    "RootPath": "storage/uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".csv", ".png", ".jpg", ".jpeg", ".txt" ]
  },
  "RabbitMq": {
    "HostName": "localhost",
    "QueueName": "taxcompliance.notifications"
  },
  "Notifications": {
    "DueSoonDays": 7,
    "ScanIntervalMinutes": 30,
    "DefaultRecipientEmail": "admin@taxplatform.local"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  }
}
